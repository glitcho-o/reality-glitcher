# Environment Configuration

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Secret (use a strong secret in production)
JWT_SECRET=reality-glitcher-super-secret-key-change-in-production

# Database Configuration (MongoDB)
MONGODB_URI=mongodb://localhost:27017/reality-glitcher

# Redis Configuration
REDIS_URL=redis://localhost:6379

# AWS S3 Configuration (for media storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=reality-glitcher-media

# Socket.io Configuration
SOCKET_CORS_ORIGIN=http://localhost:19006,http://localhost:3000

# Logging
LOG_LEVEL=debug